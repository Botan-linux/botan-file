            --colors \
            --msgbox "

\Zb\Z2  ╔═══════════════════════════════════════════════════╗
  ║                                                    ║
  ║     🌿  BOTAN LINUX  🌿                           ║
  ║                                                    ║
  ╚═══════════════════════════════════════════════════╝\Zn

\Zb$msg_complete\Zn

\Zb$msg_info\Zn
   • Username:  $USERNAME
   • Hostname: $HOST_NAME
   • Desktop:  ${DESKTOP_ENV^^}
   • Disk:        $TARGET_DISK

\Zb$msg_next\Zn
   1. Remove USB
   2. Reboot: \Zbreboot\Zn
   3. Login as $USERNAME

\Zb$msg_help\Zn
   • $msg_project: $PROJECT_URL
   • $msg_discord: $DISCORD_URL
   • $msg_bugreport: $BUG_REPORT_URL

\Z2🌿 Botan Linux - Power, Speed, Freedom\Zn

" 28 80

    # Unmount
    umount -R /mnt 2>/dev/null || true

