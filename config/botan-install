# --- STEP 6: DISK PARTITION ---

step_disk_partition() {
    # Get disk list with model info
    local disk_info=$(lsblk -p -n -o NAME,SIZE,MODEL -d 2>/dev/null | grep -E '^/dev')
    
    if [ -z "$disk_info" ]; then
        error_exit "Hiç disk bulunamadı!"
    fi

    # Create menu items
    local menu_items=""
    while IFS= read -r line; do
        local disk=$(echo "$line" | awk '{print $1}')
        local size=$(echo "$line" | awk '{print $2}')
        local model=$(echo "$line" | awk '{$1=""; $2=""; print substr($0,3)}')
        menu_items="$menu_items $disk \"$size - $model\""
    done <<< "$disk_info"

    # Disk selection
    eval $DIALOG --title \"💾 Disk Seçimi\" \
            --backtitle \"Botan Linux - Hardcore Distribution\" \
            --colors --menu \"\n\Z1⚠️  UYARI: Seçilen diskteki tüm veriler silinecek!\Zn\nKurulum yapılacak diski seçin:\" 20 75 5 $menu_items 2>$TEMPFILE || exit 1
    
    TARGET_DISK=$(cat $TEMPFILE)

    # Show disk info
    local disk_model=$(lsblk -d -o MODEL "$TARGET_DISK" -n 2>/dev/null)
    local disk_size=$(lsblk -d -o SIZE "$TARGET_DISK" -n 2>/dev/null)
    local disk_type=$(lsblk -d -o ROTA "$TARGET_DISK" -n 2>/dev/null | grep -q 0 && echo "SSD/NVMe" || echo "HDD")
    
    $DIALOG --title "💾 Disk Bilgisi" \
            --backtitle "Botan Linux - Hardcore Distribution" \
            --msgbox "\nSeçilen Disk: $TARGET_DISK\nModel: $disk_model\nKapasite: $disk_size\nTür: $disk_type" 12 50

    # Confirm disk selection
    $DIALOG --title "⚠️ Onay Gerekli" \
            --backtitle "Botan Linux - Hardcore Distribution" \
            --colors \
            --yesno "\n\Z1Seçilen disk: $TARGET_DISK ($disk_size)\Zn\n\nBu diskteki \ZbTÜM VERİLER SİLİNECEK!\Zn\n\nDevam etmek istediğinize emin misiniz?" 12 65 || exit 1

    # Partition method
    local part_method=$($DIALOG --stdout \
        --title "📋 Bölümleme Yöntemi" \
        --backtitle "Botan Linux - Hardcore Distribution" \
        --menu "\nBölümleme yöntemini seçin:" 17 65 4 \
        "auto" "Otomatik (Tüm disk silinir)" \
        "manual" "Manuel (cfdisk ile)" \
        "existing" "Mevcut Bölümü Kullan") || exit 1

    case $part_method in
        auto)
            # Swap size selection
            local ram_size=$(free -g | awk '/^Mem:/{print $2}')
            local swap_default=$((ram_size + 1))
            
            SWAP_SIZE=$($DIALOG --stdout \
                --title "💾 Swap Boyutu" \
                --backtitle "Botan Linux - Hardcore Distribution" \
                --inputbox "\nSwap boyutunu girin (GB):\n(Bellek: ${ram_size}GB, Önerilen: ${swap_default}GB)\n(0 = Swap yok)" 12 55 "$swap_default") || SWAP_SIZE="$swap_default"

            # Automatic partitioning with progress
            (
                echo 5
                echo "XXX\nDisk bilgileri okunuyor...\nXXX"
                sleep 1
                
                echo 15
                echo "XXX\nDisk imzaları temizleniyor...\nXXX"
                wipefs -a $TARGET_DISK 2>/dev/null || true
                sleep 1
                
                echo 25
                echo "XXX\nGPT bölüm tablosu oluşturuluyor...\nXXX"
                parted -s $TARGET_DISK mklabel gpt 2>/dev/null
                sleep 1
                
                echo 40
                echo "XXX\nBoot bölümü oluşturuluyor (512MB)...\nXXX"
                parted -s $TARGET_DISK mkpart ESP fat32 1MiB 513MiB 2>/dev/null
                parted -s $TARGET_DISK set 1 esp on 2>/dev/null
                sleep 1
                
                echo 55
                echo "XXX\nRoot bölümü oluşturuluyor...\nXXX"
                if [ "$SWAP_SIZE" -gt 0 ]; then
                    local swap_mb=$((SWAP_SIZE * 1024))
                    parted -s $TARGET_DISK mkpart primary ext4 513MiB -${swap_mb}MiB 2>/dev/null
                    parted -s $TARGET_DISK mkpart primary linux-swap -${swap_mb}MiB 100% 2>/dev/null
                else
                    parted -s $TARGET_DISK mkpart primary ext4 513MiB 100% 2>/dev/null
                fi
                sleep 2
                
                echo 70
                echo "XXX\nBoot bölümü biçimlendiriliyor...\nXXX"
                local boot_part="${TARGET_DISK}1"
                mkfs.vfat -F32 "$boot_part" 2>/dev/null
                sleep 1
                
                echo 80
                echo "XXX\nRoot bölümü biçimlendiriliyor...\nXXX"
                TARGET_PART="${TARGET_DISK}2"
                mkfs.ext4 -F "$TARGET_PART" 2>/dev/null
                sleep 1
                
                echo 90
                if [ "$SWAP_SIZE" -gt 0 ]; then
                    echo "XXX\nSwap bölümü hazırlanıyor...\nXXX"
                    local swap_part="${TARGET_DISK}3"
                    mkswap "$swap_part" 2>/dev/null
                    SWAP_FILE="$swap_part"
                fi
                sleep 1
                
                echo 100
                echo "XXX\n✅ Bölümleme tamamlandı!\nXXX"
            ) | $DIALOG --title "💿 Disk Bölümleniyor" \
                        --backtitle "Botan Linux - Hardcore Distribution" \
                        --gauge "" 12 70 0
            
            TARGET_PART="${TARGET_DISK}2"
            ;;
            
        manual)
            # Manual partitioning with cfdisk
            $DIALOG --title "📋 Manuel Bölümleme" \
                    --msgbox "\ncfdisk açılacak.\n\nGPT bölüm tablosu seçin ve:\n• Boot bölümü (512MB, EFI System)\n• Root bölümü (Linux filesystem)\n• Swap bölümü (opsiyonel)\noluşturun.\n\n'Write' ile kaydedin." 15 55
            
            cfdisk $TARGET_DISK || true
            
            # Select root partition
            local part_info=$(lsblk -p -n -o NAME,SIZE,TYPE $TARGET_DISK 2>/dev/null | grep part)
            local part_menu=""
            while IFS= read -r line; do
                local p=$(echo "$line" | awk '{print $1}')
                local s=$(echo "$line" | awk '{print $2}')
                part_menu="$part_menu $p \"$s\""
            done <<< "$part_info"
            
            eval $DIALOG --title \"📋 Root Bölümü Seçimi\" \
                    --backtitle \"Botan Linux - Hardcore Distribution\" \
                    --menu \"\nRoot bölümünü seçin:\" 15 60 3 $part_menu 2>$TEMPFILE || exit 1
            
            TARGET_PART=$(cat $TEMPFILE)
            
            # Format options
            local fs_type=$($DIALOG --stdout \
                --title "💿 Dosya Sistemi" \
                --backtitle "Botan Linux - Hardcore Distribution" \
                --menu "\n$TARGET_PART için dosya sistemi:" 12 55 3 \
                "ext4" "ext4 (Önerilen)" \
                "btrfs" "Btrfs (Snapshot desteği)" \
                "xfs" "XFS (Büyük diskler)") || fs_type="ext4"
            
            $DIALOG --title "💿 Biçimlendirme" \
                    --yesno "\n$TARGET_PART $fs_type olarak biçimlendirilsin mi?" 8 55 || exit 1
            
            mkfs.$fs_type -F $TARGET_PART 2>/dev/null || mkfs.ext4 -F $TARGET_PART
            ;;
            
        existing)
            # Use existing partition
            local all_parts=$(lsblk -p -n -o NAME,SIZE,TYPE 2>/dev/null | grep part)
            local part_menu=""
            while IFS= read -r line; do
                local p=$(echo "$line" | awk '{print $1}')
                local s=$(echo "$line" | awk '{print $2}')
                part_menu="$part_menu $p \"$s\""
            done <<< "$all_parts"
            
            eval $DIALOG --title \"📋 Bölüm Seçimi\" \
                    --backtitle \"Botan Linux - Hardcore Distribution\" \
                    --menu \"\nKullanılacak bölümü seçin:\" 15 60 5 $part_menu 2>$TEMPFILE || exit 1
            
            TARGET_PART=$(cat $TEMPFILE)
            
            # Ask to format
            $DIALOG --title "💿 Biçimlendirme" \
                    --yesno "\n$TARGET_PART biçimlendirilsin mi?\n(Hayır = Mevcut verileri koru)" 9 55 || true
            
            if [ $? -eq 0 ]; then
                mkfs.ext4 -F $TARGET_PART
            fi
            ;;
    esac

    success_msg "Disk: $TARGET_DISK\nBölüm: $TARGET_PART"
}

