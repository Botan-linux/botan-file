# --- STEP 10: INSTALLATION ---

fetch_file() {
    local source_url=$1
    local filename=$2
    local target=$3
    curl -sL "${source_url}/$filename" -o "$target" 2>/dev/null
}

step_install() {
    (
        # Prepare mount point
        echo 2
        echo "XXX\nBağlantı noktası hazırlanıyor...\nXXX"
        mkdir -p /mnt/boot 2>/dev/null || true
        sleep 1
        
        # Mount partition
        echo 5
        echo "XXX\nRoot bölümü bağlanıyor...\nXXX"
        mount $TARGET_PART /mnt 2>/dev/null || error_exit "Bölüm bağlanamadı!"
        sleep 1

        # Mount boot partition for UEFI
        echo 8
        echo "XXX\nBoot bölümü bağlanıyor...\nXXX"
        local boot_part="${TARGET_DISK}1"
        if [ -b "$boot_part" ]; then
            mkdir -p /mnt/boot/efi 2>/dev/null || true
            mount "$boot_part" /mnt/boot/efi 2>/dev/null || mount "$boot_part" /mnt/boot 2>/dev/null || true
        fi
        sleep 1

        # USB LIVE SİSTEMDEN TEMEL DOSYALARI KOPYALA
        echo 12
        echo "XXX\nUSB'den sistem dosyaları kopyalanıyor...\n(Bu işlem birkaç dakika sürebilir)\nXXX"
        if [ -d "$USB_ROOT" ]; then
            # Tüm sistemi USB'den diske kopyala
            # ISO'ya özel dosyaları Hariç TUT (bunlar silinecek/exclude)
            rsync -aAX --info=progress2 \
                --exclude="/dev/*" --exclude="/proc/*" --exclude="/sys/*" \
                --exclude="/tmp/*" --exclude="/run/*" --exclude="/mnt/*" \
                --exclude="/media/*" --exclude="/lost+found" \
                --exclude="/usr/bin/botan-installer" \
                --exclude="/usr/bin/botan" \
                --exclude="/usr/bin/mkarchiso" \
                --exclude="/etc/systemd/system/getty@tty1.service.d/autologin.conf" \
                --exclude="/etc/motd" \
                --exclude="/etc/sudoers.d/grml" \
                --exclude="/var/cache/pacman/pkg/*" \
                --exclude="/var/lib/pacman/sync/*.db" \
                --exclude="/var/log/pacman.log" \
                --exclude="/boot/memtest86+" \
                "$USB_ROOT/" "/mnt/" 2>/dev/null || true
        fi
        sleep 1
        
        # Kopyalama sonrası ek temizlik (geri kalan ISO artifact'leri)
        echo 18
        echo "XXX\nISO artifact'leri temizleniyor...\nXXX"
        rm -rf /mnt/usr/bin/botan-installer 2>/dev/null || true
        rm -rf /mnt/usr/bin/botan 2>/dev/null || true
        rm -rf /mnt/usr/bin/mkarchiso 2>/dev/null || true
        rm -rf /mnt/etc/systemd/system/getty@tty1.service.d/autologin.conf 2>/dev/null || true
        rm -rf /mnt/etc/motd 2>/dev/null || true
        rm -rf /mnt/etc/sudoers.d/grml 2>/dev/null || true
        rm -rf /mnt/var/cache/pacman/pkg/* 2>/dev/null || true
        rm -rf /mnt/var/lib/pacman/sync/*.db 2>/dev/null || true
        rm -rf /mnt/var/log/pacman.log 2>/dev/null || true
        rm -rf /mnt/tmp/* 2>/dev/null || true
        rm -rf /mnt/boot/memtest86+ 2>/dev/null || true
        sleep 1

        # Install additional packages with pacstrap
        echo 25
        echo "XXX\nEk paketler yükleniyor...\n(pacstrap çalışıyor)\nXXX"
        
        # Sadece USB'de olmayan paketleri kur
        # Desktop environment ve ek paketler
        local extra_packages=""
        
        case $DESKTOP_ENV in
            kde)    extra_packages="plasma konsole dolphin" ;;
            gnome)  extra_packages="gnome gnome-terminal nautilus" ;;
            xfce)   extra_packages="xfce4 xfce4-goodies" ;;
            mate)   extra_packages="mate mate-extra" ;;
            cinnamon) extra_packages="cinnamon" ;;
            lxqt)   extra_packages="lxqt" ;;
            i3)     extra_packages="i3-wm i3status dmenu" ;;
            sway)   extra_packages="sway waybar" ;;
        esac
        
        # Add extra packages
        if [ -n "$EXTRA_PACKAGES" ]; then
            extra_packages="$extra_packages $EXTRA_PACKAGES"
        fi
        
        # Pacstrap ile sadece ek paketleri kur
        if [ -n "$extra_packages" ]; then
            pacstrap /mnt $extra_packages 2>&1 || true
        fi

        # Generate fstab
        echo 35
        echo "XXX\nfstab oluşturuluyor...\nXXX"
        genfstab -U /mnt >> /mnt/etc/fstab
        
        # Add swap to fstab if exists
        if [ -n "$SWAP_FILE" ] && [ -b "$SWAP_FILE" ]; then
            local swap_uuid=$(blkid -s UUID -o value $SWAP_FILE)
            echo "UUID=$swap_uuid none swap defaults 0 0" >> /mnt/etc/fstab
        fi
        sleep 1

        # Fetch configuration files
        echo 40
        echo "XXX\nYapılandırma dosyaları indiriliyor...\nXXX"
        mkdir -p /mnt/etc /mnt/boot 2>/dev/null
        
        # From config folder
        fetch_file "$CONFIG_URL" "os-release" "/mnt/etc/os-release"
        fetch_file "$CONFIG_URL" "pacman.conf" "/mnt/etc/pacman.conf"
        
        sleep 1

        # System configuration
        echo 50
        echo "XXX\nSistem ayarları yapılandırılıyor...\nXXX"
        
        # Hostname
        echo "$HOST_NAME" > /mnt/etc/hostname
        
        # Hosts file
        cat > /mnt/etc/hosts << EOF
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOST_NAME.localdomain $HOST_NAME
EOF
        
        # Locale
        echo "$LOCALE UTF-8" >> /mnt/etc/locale.gen
        echo "LANG=$LOCALE" > /mnt/etc/locale.conf
        echo "KEYMAP=$KEYBOARD_LAYOUT" > /mnt/etc/vconsole.conf
        
        # Timezone
        ln -sf /usr/share/zoneinfo/$TIMEZONE /mnt/etc/localtime
        
        # Enable services
        echo 55
        echo "XXX\nServisler etkinleştiriliyor...\nXXX"
        sleep 1

        # User creation in chroot
        echo 60
        echo "XXX\nKullanıcı oluşturuluyor...\nXXX"
        
        arch-chroot /mnt bash -c "
            # Set root password
            echo 'root:$ROOT_PASS' | chpasswd
            
            # Create user
            useradd -m -G wheel,video,audio,storage -s /bin/bash $USERNAME
            echo '$USERNAME:$USER_PASS' | chpasswd
            
            # Enable sudo for wheel group
            sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers
            
            # Generate locale
            locale-gen
            
            # Enable NetworkManager
            systemctl enable NetworkManager
            
            # Enable display manager based on desktop
            case '$DESKTOP_ENV' in
                kde)    systemctl enable sddm ;;
                gnome)  systemctl enable gdm ;;
                xfce|mate|cinnamon|lxqt) systemctl enable lightdm || true ;;
            esac
        "
        sleep 1

        # Bootloader installation
        echo 75
        echo "XXX\nGRUB bootloader kuruluyor...\nXXX"
        
        # GRUB kurulumu - chroot içinde
        arch-chroot /mnt bash -c "
            # BIOS kurulumu
            if [ -d /sys/firmware/efi ]; then
                # UEFI
                grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Botan --recheck
            else
                # BIOS
                grub-install --target=i386-pc $TARGET_DISK
            fi
            
            # GRUB yapılandırması oluştur
            grub-mkconfig -o /boot/grub/grub.cfg
        " 2>/dev/null || true
        
        sleep 1

        # USB'DEN TÜM ÖNEMLİ DOSYALARI KOPYALA
        echo 82
        echo "XXX\nUSB Live sistemden dosyalar kopyalanıyor...\nXXX"
        
        # USB airootfs'ten rsync ile kopyala (eğer mevcutsa)
        if [ -d "$USB_ROOT" ]; then
            # Temel sistem dosyaları
            rsync -a --exclude="/dev/*" --exclude="/proc/*" --exclude="/sys/*" \
                  --exclude="/tmp/*" --exclude="/run/*" --exclude="/mnt/*" \
                  --exclude="/media/*" --exclude="/lost+found" \
                  "$USB_ROOT/usr/share/" "/mnt/usr/share/" 2>/dev/null || true
            rsync -a "$USB_ROOT/usr/lib/" "/mnt/usr/lib/" 2>/dev/null || true
            rsync -a "$USB_ROOT/usr/bin/" "/mnt/usr/bin/" 2>/dev/null || true
            rsync -a "$USB_ROOT/usr/libexec/" "/mnt/usr/libexec/" 2>/dev/null || true
        fi
        
        # USB'den özel dosyalar
        for dir in wallpapers themes icons fonts backgrounds botan sounds; do
            [ -d "/usr/share/$dir" ] && cp -r "/usr/share/$dir" "/mnt/usr/share/" 2>/dev/null || true
        done
        
        # Özel scriptler
        for script in botan-installer botan-welcome botan-settings botan-update; do
            [ -f "/usr/bin/$script" ] && cp "/usr/bin/$script" "/mnt/usr/bin/" 2>/dev/null || true
        done
        
        # /etc/skel - kullanıcı şablonları
        if [ -d /etc/skel ]; then
            cp -r /etc/skel/* "/mnt/home/$USERNAME/" 2>/dev/null || true
            cp -r /etc/skel/.config "/mnt/home/$USERNAME/" 2>/dev/null || true
            cp -r /etc/skel/.local "/mnt/home/$USERNAME/" 2>/dev/null || true
            chown -R 1000:1000 "/mnt/home/$USERNAME" 2>/dev/null || true
        fi
        
        # /etc özel config dosyaları
        for file in doas.conf mkinitcpio.conf locale.gen vconsole.conf; do
            [ -f "/etc/$file" ] && cp "/etc/$file" "/mnt/etc/$file" 2>/dev/null || true
        done
        for dir in modprobe.d modules-load.d sysctl.d X11 xdg; do
            [ -d "/etc/$dir" ] && cp -r "/etc/$dir" "/mnt/etc/" 2>/dev/null || true
        done
        
        # /opt özel programlar
        [ -d /opt ] && cp -r /opt/* /mnt/opt/ 2>/dev/null || true
        
        # /usr/lib önemli dosyalar
        for dir in firmware modules modprobe.d; do
            [ -d "/usr/lib/$dir" ] && cp -r "/usr/lib/$dir" "/mnt/usr/lib/" 2>/dev/null || true
        done
        
        # Var壁纸 ve temalar
        [ -d /var/lib ] && cp -r /var/lib/* /mnt/var/lib/ 2>/dev/null || true
        
        sleep 1

        # Final setup
        echo 95
        echo "XXX\nSon yapılandırmalar yapılıyor...\nXXX"
        
        # Create initramfs
        arch-chroot /mnt mkinitcpio -P 2>/dev/null || true
        
        # Sync
        sync
        
        sleep 1

        echo 100
        echo "XXX\n✅ Kurulum tamamlandı!\nXXX"
        sleep 2
        
    ) | $DIALOG --title "🌿 Botan Linux Kuruluyor" \
                --backtitle "Botan Linux - Hardcore Distribution" \
                --gauge "" 12 70 0
}

